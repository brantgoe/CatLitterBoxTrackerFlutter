<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext traffic only to LAN destinations so the master/client
  WebSocket on a local IP works without globally weakening HTTPS expectations.
  Public hosts continue to require TLS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!--
          RFC1918 private IPv4 ranges. Network Security Config does not have a
          CIDR syntax, so we enumerate the /16 prefixes that cover the common
          home/SOHO subnets. Routers reliably use one of:
            192.168.0.0/16  → 192.168.x.x (most common consumer)
            10.0.0.0/8      → 10.x.x.x    (often used by mesh/business)
            172.16.0.0/12   → 172.16.x.x  – 172.31.x.x
          The .local TLD is for mDNS / Bonjour service discovery.
        -->
        <domain includeSubdomains="true">.local</domain>
    </domain-config>
</network-security-config>
